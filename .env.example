# Valyd Docs — per-server environment configuration
#
# Copy this file to `.env` on each server and fill in that server's URLs, then
# rebuild (`npm run build` / `bun run build`). Only VITE_-prefixed vars are
# exposed to the client, and they are inlined at BUILD time — a config change
# requires a rebuild + redeploy of `dist/`.
#
# All keys are optional; anything left unset falls back to the development
# (.pollus.tech) defaults baked into src/lib/api-config.ts.
#
# ----------------------------------------------------------------------------
# Development server  (docs.pollus.tech)  — these are also the code defaults:
# ----------------------------------------------------------------------------
VITE_IDP_BASE_URL=https://idp.pollus.tech
VITE_API_BASE_URL=https://idp.pollus.tech/api/auth/tpsso
VITE_DEV_PORTAL_URL=https://dev.pollus.tech
VITE_DOCS_BASE_URL=https://docs.pollus.tech
VITE_VERIFY_BASE_URL=https://verify.pollus.tech
VITE_VERIFY_CONSOLE_URL=https://verify.pollus.tech/dashboard

# Sandbox ("Try the APIs") — defaults to the IdP above if unset
# VITE_SANDBOX_BASE_URL=https://idp.pollus.tech
VITE_SANDBOX_CLIENT_ID=sandbox_pollus_test
VITE_SANDBOX_CLIENT_SECRET=sk_test_pollus_xxxxxxxxxxxxxxxx

VITE_BRAND_NAME=Valyd

# ----------------------------------------------------------------------------
# Testing server  (docs.pollus.online)  — adjust to the real testing domains:
# ----------------------------------------------------------------------------
# VITE_IDP_BASE_URL=https://idp.pollus.online
# VITE_API_BASE_URL=https://idp.pollus.online/api/auth/tpsso
# VITE_DEV_PORTAL_URL=https://dev.pollus.online
# VITE_DOCS_BASE_URL=https://docs.pollus.online
# VITE_VERIFY_BASE_URL=https://verify.pollus.online
# VITE_VERIFY_CONSOLE_URL=https://verify.pollus.online/dashboard

# ----------------------------------------------------------------------------
# Production server  (docs.valyd.id)  — adjust to the real production domains:
# ----------------------------------------------------------------------------
# VITE_IDP_BASE_URL=https://idp.valyd.id
# VITE_API_BASE_URL=https://idp.valyd.id/api/auth/tpsso
# VITE_DEV_PORTAL_URL=https://dev.valyd.id
# VITE_DOCS_BASE_URL=https://docs.valyd.id
# VITE_VERIFY_BASE_URL=https://verify.valyd.id
# VITE_VERIFY_CONSOLE_URL=https://verify.valyd.id/dashboard
